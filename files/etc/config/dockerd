
config globals 'globals'
	list dns 'fd00:ac1f:dc::1'
	list dns '172.31.0.1'
	list hosts 'unix:///var/run/docker.sock'
	list registry_mirrors 'https://docker.1panel.live'
	list registry_mirrors 'https://docker.1ms.run'
	list registry_mirrors 'https://hub.rat.dev'
	list registry_mirrors 'https://dockerproxy.net'
	list registry_mirrors 'https://proxy.vvvv.ee'
	list registry_mirrors 'https://hub.docker.com'
#	option alt_config_file '/etc/docker/daemon.json'
	option bip '172.31.0.1/24'
	option data_root '/opt/docker/'
	option default_gateway_v6 'fd00:ac1f:dc::1'
	option default_gateway '172.31.0.1'
	option dns_opts 'use-vc'
	option experimental 'true'
	option fixed_cidr_v6 'fd00:ac1f:dc::/120'
	option fixed_cidr '172.31.0.0/24'
#	option iptables 'true'
	option ipv6 'true'
#	option ipv6tables 'true'
	option log_level 'error'

config firewall 'firewall'
#	list blocked_interfaces 'wan'
	option device 'docker0'
